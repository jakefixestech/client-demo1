---
import "../styles/global.css";

const navLinks = [
  { label: "Home", href: "#home" },
  { label: "About", href: "#about" },
  { label: "Portfolio", href: "#portfolio" },
  { label: "Services", href: "#services" },
  { label: "Testimonials", href: "#testimonials" },
  { label: "Contact", href: "#contact" },
];

const galleries = [
  {
    title: "Senior Portraits",
    href: "#senior-portraits",
    img: "/senior.jpg",
    alt: "A high school senior standing outdoors among tall grasses during a fall senior portrait session.",
  },
  {
    title: "Couples",
    href: "#couples",
    img: "/couples.png",
    alt: "A couple laughing together during a relaxed outdoor photo session.",
  },
  {
    title: "Engagement",
    href: "#engagement",
    img: "/engagement.jpg",
    alt: "A couple in autumn flannel sharing a quiet moment during an engagement session.",
  },
  {
    title: "Family",
    href: "#family",
    img: "/family.jpg",
    alt: "A mother and father holding their baby in front of golden autumn birch trees backlit by the sun.",
  },
  {
    title: "Maternity",
    href: "#maternity",
    img: "/maternity.jpg",
    alt: "An expectant couple standing in a sunlit field, holding up a strip of black-and-white ultrasound photos.",
  },
  {
    title: "Pet Photography",
    href: "#pet-photography",
    img: "/pet.jpg",
    alt: "A close-up portrait of a chocolate Labrador's face, with warm light catching its eye.",
  },
  {
    title: "Events & Parties",
    href: "#events",
    img: "/events.jpg",
    alt: "A soccer player in a number 3 jersey raising an arm on the field under the lights at dusk.",
  },
];
---

<!doctype html>
<html lang="en" class="bg-white scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Meredith Lewis Photography — capturing candid, heartfelt moments throughout the White Mountains of New Hampshire, Maine, and Vermont. Approachable, affordable portrait and event photography."
    />
    <title>Meredith Lewis Photography | White Mountains, NH</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />

    <!-- Google Fonts: Playfair Display (serif) + Inter (sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --font-serif: "Playfair Display", Georgia, serif;
        --font-sans: "Inter", system-ui, sans-serif;
      }
      body {
        font-family: var(--font-sans);
      }
      .font-serif {
        font-family: var(--font-serif);
      }
    </style>
  </head>

  <body class="bg-white text-neutral-900 antialiased">
    <!-- ===================== NAV ===================== -->
    <header
      id="site-nav"
      class="fixed inset-x-0 top-0 z-50 transition-colors duration-300"
    >
      <nav
        aria-label="Primary"
        class="mx-auto flex max-w-7xl items-center justify-between px-5 py-5 sm:px-8 lg:px-12"
      >
        <a
          href="#home"
          id="wordmark"
          class="font-serif text-lg font-medium tracking-tight text-white transition-colors duration-300 sm:text-xl"
        >
          Meredith Lewis Photography
        </a>

        <!-- Desktop nav -->
        <div class="hidden items-center gap-8 lg:flex">
          <ul class="flex items-center gap-7">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="nav-link text-sm font-light tracking-wide text-white/90 transition-colors duration-300 hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <a
            href="#contact"
            class="nav-cta rounded-full border border-white/70 px-5 py-2 text-sm font-light tracking-wide text-white transition-colors duration-300 hover:bg-white hover:text-neutral-900"
          >
            Get in Touch
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button
          id="menu-toggle"
          type="button"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="flex h-10 w-10 items-center justify-center lg:hidden"
        >
          <span class="sr-only">Open menu</span>
          <svg
            id="icon-open"
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-white"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
          </svg>
          <svg
            id="icon-close"
            xmlns="http://www.w3.org/2000/svg"
            class="hidden h-6 w-6 text-neutral-900"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </nav>

      <!-- Mobile menu panel -->
      <div
        id="mobile-menu"
        class="hidden border-t border-neutral-200 bg-white lg:hidden"
      >
        <ul class="flex flex-col px-5 py-4 sm:px-8">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="mobile-link block border-b border-neutral-100 py-3 text-sm font-light tracking-wide text-neutral-700 hover:text-neutral-900"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          <li class="pt-4">
            <a
              href="#contact"
              class="mobile-link block rounded-full border border-neutral-900 px-5 py-3 text-center text-sm font-light tracking-wide text-neutral-900 hover:bg-neutral-900 hover:text-white"
            >
              Get in Touch
            </a>
          </li>
        </ul>
      </div>
    </header>

    <main>
      <!-- ===================== HERO ===================== -->
      <section id="home" class="relative h-screen min-h-[600px] w-full">
        <img
          src="/hero1.jpg"
          alt="An elevated view of a New Hampshire notch in the White Mountains, with peak autumn foliage covering the mountainsides above a lake and a winding road."
          class="absolute inset-0 h-full w-full object-cover"
        />
        <!-- Dark gradient scrim at the bottom for legibility -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-black/10"
        >
        </div>
        <!-- Soft top scrim so the nav reads over the bright sky -->
        <div
          class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-black/50 to-transparent"
        >
        </div>

        <div
          class="relative z-10 mx-auto flex h-full max-w-7xl flex-col justify-end px-5 pb-24 sm:px-8 sm:pb-28 lg:px-12"
        >
          <h1
            class="max-w-3xl font-serif text-3xl font-medium leading-tight text-white text-balance [text-shadow:0_2px_16px_rgba(0,0,0,0.55)] sm:text-4xl md:text-4xl lg:text-5xl"
          >
            Capturing candid &amp; heartfelt moments throughout the White
            Mountains of New Hampshire.
          </h1>
        </div>

        <!-- Scroll-down cue -->
        <a
          href="#about"
          aria-label="Scroll down to learn more"
          class="absolute bottom-8 left-1/2 z-10 flex -translate-x-1/2 flex-col items-center gap-2 text-white/80 transition-colors hover:text-white"
        >
          <span class="text-[11px] font-light uppercase tracking-[0.25em]">Scroll</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 animate-bounce"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </a>
      </section>

      <!-- ===================== INTRO ===================== -->
      <section id="about" class="bg-white px-5 py-24 sm:px-8 sm:py-32 lg:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <p
            class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500"
          >
            Hello &amp; welcome
          </p>
          <h2
            class="font-serif text-3xl font-medium leading-snug text-neutral-900 text-balance sm:text-4xl"
          >
            So glad you&apos;re here.
          </h2>
          <p
            class="mx-auto mt-8 max-w-2xl text-lg font-light leading-relaxed text-neutral-600 text-pretty"
          >
            A New Hampshire based photography business rooted in the picturesque
            White Mountains, capturing candid, meaningful moments that feel
            genuine and tell your story in a way that&apos;s true to you — all
            while keeping photography approachable and affordable.
          </p>
        </div>
      </section>

      <!-- ===================== PORTFOLIO PREVIEW ===================== -->
      <section
        id="portfolio"
        class="bg-neutral-50 px-5 py-24 sm:px-8 sm:py-28 lg:px-12"
      >
        <div class="mx-auto max-w-7xl">
          <div class="mb-12 text-center">
            <p
              class="mb-4 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500"
            >
              Portfolio
            </p>
            <h2 class="font-serif text-3xl font-medium text-neutral-900 sm:text-4xl">
              Explore the Galleries.
            </h2>
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {
              galleries.map((g, i) => (
                <a
                  href={g.href}
                  class={`group relative block overflow-hidden bg-neutral-200 ${
                    i === 0 ? "lg:col-span-2 lg:row-span-2" : ""
                  } ${
                    i === galleries.length - 1 ? "sm:col-span-2 lg:col-span-3" : ""
                  }`}
                >
                  <img
                    src={g.img}
                    alt={g.alt}
                    loading="lazy"
                    class={`h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 ${
                      i === 0
                        ? "aspect-[4/5] lg:aspect-auto"
                        : i === galleries.length - 1
                          ? "aspect-[4/5] sm:aspect-[16/7]"
                          : "aspect-[4/5]"
                    }`}
                  />
                  <div class="absolute inset-0 bg-black/0 transition-colors duration-300 group-hover:bg-black/50" />
                  <div
                    class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/70 via-black/20 to-transparent transition-opacity duration-300 group-hover:opacity-0"
                  />
                  <div class="absolute inset-0 flex items-center justify-center">
                    <span class="font-serif text-2xl text-white opacity-0 translate-y-2 [text-shadow:0_2px_14px_rgba(0,0,0,0.7)] transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0 sm:text-3xl">
                      {g.title}
                    </span>
                  </div>
                  <span class="absolute bottom-5 left-5 text-lg font-normal tracking-wide text-white drop-shadow-md group-hover:opacity-0 transition-opacity duration-300">
                    {g.title}
                  </span>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ===================== AFFORDABLE BAND ===================== -->
      <section
        id="services"
        class="bg-neutral-900 px-5 py-24 text-center sm:px-8 sm:py-28 lg:px-12"
      >
        <div class="mx-auto max-w-3xl">
          <p
            class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500"
          >
            Photography for everyone
          </p>
          <h2
            class="font-serif text-3xl font-medium leading-snug text-white text-balance sm:text-4xl"
          >
            Everyone deserves beautiful photographs.
          </h2>
          <p
            class="mx-auto mt-8 max-w-2xl text-lg font-light leading-relaxed text-neutral-300 text-pretty"
          >
            I believe the moments that matter most shouldn&apos;t be out of
            reach. That&apos;s why I host seasonal
            <span class="text-white">&ldquo;Pay What You Can&rdquo;</span> mini
            sessions — a warm, no-pressure way for families and individuals to
            have their stories captured, no matter the budget. Great photos,
            made approachable.
          </p>
        </div>
      </section>

      <!-- ===================== FEATURED TESTIMONIALS ===================== -->
      <section
        id="testimonials"
        class="bg-white px-5 py-24 sm:px-8 sm:py-32 lg:px-12"
      >
        <div class="mx-auto max-w-6xl">
          <div class="mb-16 text-center">
            <p
              class="mb-4 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500"
            >
              Kind words
            </p>
            <h2 class="font-serif text-3xl font-medium text-neutral-900 sm:text-4xl">
              From the people I&apos;ve worked with.
            </h2>
          </div>

          <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:gap-16">
            <figure class="text-center md:text-left">
              <blockquote
                class="font-serif text-2xl font-normal italic leading-relaxed text-neutral-800 text-pretty sm:text-[1.75rem]"
              >
                &ldquo;110% recommend! Meredith went above and beyond to make
                sure we were comfortable with all poses. She was fun, energetic
                and anyone that can make my fianc&eacute; laugh and naturally
                smile in photos gets my stamp of approval.&rdquo;
              </blockquote>
              <figcaption
                class="mt-6 text-sm font-medium uppercase tracking-[0.2em] text-neutral-500"
              >
                — Alyssa S.
              </figcaption>
            </figure>

            <figure class="text-center md:text-left">
              <blockquote
                class="font-serif text-2xl font-normal italic leading-relaxed text-neutral-800 text-pretty sm:text-[1.75rem]"
              >
                &ldquo;She was able to get my son to relax and take great senior
                photos &mdash; so many great pictures! She captured the moment
                beautifully during an emotional time. I would whole heartedly
                recommend her for any task. Great job, great photographer, great
                person!&rdquo;
              </blockquote>
              <figcaption
                class="mt-6 text-sm font-medium uppercase tracking-[0.2em] text-neutral-500"
              >
                — Susan G.
              </figcaption>
            </figure>
          </div>
        </div>
      </section>

      <!-- ===================== CLOSING CTA ===================== -->
      <section id="contact" class="relative w-full">
        <img
          src="/bottom.jpg"
          alt="A loon stretching its wings on a calm lake, water droplets falling from its feathers."
          loading="lazy"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-black/60"></div>

        <div
          class="relative z-10 mx-auto flex max-w-3xl flex-col items-center px-5 py-32 text-center sm:px-8 sm:py-40 lg:px-12"
        >
          <h2
            class="font-serif text-4xl font-medium leading-tight text-white text-balance sm:text-5xl"
          >
            Let&apos;s tell your story.
          </h2>
          <p
            class="mt-6 max-w-xl text-lg font-light leading-relaxed text-white/80 text-pretty"
          >
            Whether it&apos;s a milestone, a celebration, or an ordinary day
            worth remembering — I&apos;d love to hear from you.
          </p>
          <a
            href="mailto:hello@meredithlewisphoto.com"
            class="mt-10 inline-block rounded-full bg-white px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-neutral-900 transition-colors hover:bg-neutral-200"
          >
            Get in Touch
          </a>
        </div>
      </section>
    </main>

    <!-- ===================== FOOTER ===================== -->
    <footer class="bg-white px-5 py-16 sm:px-8 lg:px-12">
      <div class="mx-auto max-w-7xl">
        <div
          class="flex flex-col items-center gap-8 border-b border-neutral-200 pb-12 text-center"
        >
          <a href="#home" aria-label="Meredith Lewis Photography — home">
            <img
              src="/logo.png"
              alt="Meredith Lewis Photography — based in the White Mountains, ME, NH &amp; VT, established 2019."
              width="760"
              height="485"
              class="h-64 w-auto sm:h-80"
            />
          </a>

          <nav aria-label="Footer" class="flex flex-wrap justify-center gap-x-6 gap-y-3">
            {
              navLinks.map((link) => (
                <a
                  href={link.href}
                  class="text-sm font-light tracking-wide text-neutral-800 transition-colors hover:text-neutral-900"
                >
                  {link.label}
                </a>
              ))
            }
          </nav>

          <a
            href="https://www.facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit Meredith Lewis Photography on Facebook"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898v-2.89h2.54V9.797c0-2.507 1.492-3.892 3.777-3.892 1.094 0 2.238.196 2.238.196v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12Z"
              ></path>
            </svg>
          </a>
        </div>

        <p class="mt-8 text-center text-xs font-light tracking-wide text-neutral-700">
          &copy; {new Date().getFullYear()} Meredith Lewis Photography. All rights reserved.
        </p>
      </div>
    </footer>

    <!-- ===================== VANILLA JS ===================== -->
    <script>
      // Nav background on scroll
      const nav = document.getElementById("site-nav");
      const wordmark = document.getElementById("wordmark");
      const navLinkEls = document.querySelectorAll(".nav-link");
      const navCta = document.querySelector(".nav-cta");
      const iconOpenEl = document.getElementById("icon-open");

      const onScroll = () => {
        const scrolled = window.scrollY > 40;
        if (scrolled) {
          nav?.classList.add("bg-white", "shadow-sm");
          wordmark?.classList.remove("text-white");
          wordmark?.classList.add("text-neutral-900");
          navLinkEls.forEach((el) => {
            el.classList.remove("text-white/90", "hover:text-white");
            el.classList.add("text-neutral-700", "hover:text-neutral-900");
          });
          navCta?.classList.remove("border-white/70", "text-white", "hover:bg-white", "hover:text-neutral-900");
          navCta?.classList.add("border-neutral-900", "text-neutral-900", "hover:bg-neutral-900", "hover:text-white");
          iconOpenEl?.classList.remove("text-white");
          iconOpenEl?.classList.add("text-neutral-900");
        } else {
          nav?.classList.remove("bg-white", "shadow-sm");
          wordmark?.classList.add("text-white");
          wordmark?.classList.remove("text-neutral-900");
          navLinkEls.forEach((el) => {
            el.classList.add("text-white/90", "hover:text-white");
            el.classList.remove("text-neutral-700", "hover:text-neutral-900");
          });
          navCta?.classList.add("border-white/70", "text-white", "hover:bg-white", "hover:text-neutral-900");
          navCta?.classList.remove("border-neutral-900", "text-neutral-900", "hover:bg-neutral-900", "hover:text-white");
          iconOpenEl?.classList.add("text-white");
          iconOpenEl?.classList.remove("text-neutral-900");
        }
      };

      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      // Mobile menu toggle
      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const iconOpen = document.getElementById("icon-open");
      const iconClose = document.getElementById("icon-close");

      const closeMenu = () => {
        menu?.classList.add("hidden");
        iconOpen?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
        toggle?.setAttribute("aria-expanded", "false");
      };

      toggle?.addEventListener("click", () => {
        const isOpen = !menu?.classList.contains("hidden");
        if (isOpen) {
          closeMenu();
        } else {
          menu?.classList.remove("hidden");
          iconOpen?.classList.add("hidden");
          iconClose?.classList.remove("hidden");
          toggle?.setAttribute("aria-expanded", "true");
        }
      });

      // Close mobile menu when a link is tapped
      document.querySelectorAll(".mobile-link").forEach((link) => {
        link.addEventListener("click", closeMenu);
      });
    </script>
  </body>
</html>
